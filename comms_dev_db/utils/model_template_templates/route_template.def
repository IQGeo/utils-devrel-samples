            "external_name": "Length",
            "type": "double"
        },
        {
            "name": "conduits",
            "external_name": "Conduits",
            "type": "reference_set()",
            "value": "select(*)"
        },
        {
            "name": "cable_segments",
            "external_name": "Cable Segments",
            "type": "reference_set()",
            "value": "select(*)"
        }
    ]
