      <RuleScalingEquipmentToDemand>
        <equipmentType>CPE_P2P</equipmentType>
        <equipmentTypeToScaleTo>P2P_HOME</equipmentTypeToScaleTo>
        <scalingFactor>1.0</scalingFactor>
        <rounding>NO</rounding>
