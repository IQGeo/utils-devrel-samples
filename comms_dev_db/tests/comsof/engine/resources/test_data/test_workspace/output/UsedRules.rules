        <splitterMap class="map">
          <entry>
            <FiberType>pon</FiberType>
            <list>
              <Pair>
                <first class="int">1</first>
                <second class="SplitterDescription">
                  <splitterType identifier="1:1">Splitter</splitterType>
                  <outgoingFiberType>pon_stdSplitterScheme</outgoingFiberType>
                </second>
              </Pair>
            </list>
          </entry>
