[
   {
      "datasource": "myworld", 
      "name": "ftth_circuit",
      "external_name": "Circuit",
      "title": "{display_name}: [name]", 
      "short_description": "[service_type] ([status])",
      "searches": [
         { "value": "[name]", "description": "{title}" },
         { "value": "[customer]", "description": "{title} [customer]" }
      ],
      "groups": [
         {
            "name": "Properties", 
            "fields": [
               "name",
               "service_type",
               "status",
               "customer",
               "address",
               "in_feature",
               "in_pins",
               "out_feature",
               "out_pins"
            ], 
            "expanded": true
         }
      ]
   }
]
