{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Fetch node_modules",
            "type": "shell",
            "command": "myw_product fetch node_modules",
            "problemMatcher": []
        },
        {
            "label": "Watch Applications Dev",
            "type": "shell",
            "command": "myw_product watch applications_dev --debug",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build code package & export",
            "type": "shell",
            "command": "myw_product build code_package && myw_db myw_dev export --include_code"
        },
        {
            "label": "Restart Python env in Apache",
            "type": "shell",
            "command": "touch /opt/iqgeo/platform/WebApps/myworldapp.wsgi",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Build All Dev",
            "type": "shell",
            "command": "myw_product build base --debug && myw_product build client --debug && myw_product build config && myw_product build applications_dev --debug",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Build Extract",
            "type": "shell",
            "command": "build_extract 'test'",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Build Config",
            "type": "shell",
            "command": "myw_product build config",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Build Applications",
            "type": "shell",
            "command": "myw_product build applications_dev --debug",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Watch Applications",
            "type": "shell",
            "command": "myw_product watch applications --debug",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "View Apache Error Log",
            "type": "shell",
            "command": "code /var/log/apache2/error.log",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Build Database",
            "type": "shell",
            "command": "./comms_dev_db/utils/comms_build_dev_db",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run Client Tests (selenium) - From Docker",
            "type": "shell",
            "command": "./comms_dev_db/tests/client/comms_client_tests",
            "args": [
                "run",
                "add_structure",
                // "cdiff",
                "--remote_url",
                "http://host.docker.internal:4444/wd/hub",
                "--base_url",
                "http://localhost:${env:APP_PORT}"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Client Tests (selenium) - From Docker Linux",
            "type": "shell",
            "command": "./comms_dev_db/tests/client/comms_client_tests",
            "args": [
                "run",
                "split_route",
                "cdiff",
                "--remote_url",
                "http://172.17.0.1:4444/wd/hub",
                "--base_url",
                "http://172.17.0.1:${env:APP_PORT}"
                // "--delay",
                // "2.0"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Restart Apache",
            "type": "shell",
            "command": "httpd",
            "args": ["-k", "restart"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
