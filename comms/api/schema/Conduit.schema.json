{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "Conduit.schema.json",
    "title": "Conduit",
    "definitions": {
        "Conduit": {
            "$id": "#Conduit",
            "description": "Conduit is an abstract entity that describes the common set of attributes shared by all IQGeo features.",
            "type": "object",
            "properties": {
                "name": {
                    "description": "The name of the Conduit",
                    "type": "string"
                },
                "specification": {
                    "description": "The specification of the cable",
                    "type": "string"
                },
                "housing": {
                    "description": "Structure or equipment that is direct parent (URN).",
                    "type": "string"
                },
                "rootHousing": {
                    "description": "Structure in which object is housed (URN).",
                    "type": "string"
                },
                "inStructure": {
                    "description": "Start structure, if any (URN)",
                    "type": "string"
                },
                "outStructure": {
                    "description": "End structure, if any (URN)",
                    "type": "string"
                },
                "inConduit": {
                    "description": "Previous conduit in chain (continous conduits only) (URN)",
                    "type": "string"
                },
                "outConduit": {
                    "description": "Next conduit in chain (continous conduits only) (URN)",
                    "type": "string"
                },
                "conduitRun": {
                    "description": "Conduit run of which object is a part (continuous conduits only) (URN).",
                    "type": "string"
                },
                "laborCosts": {
                    "description": "Labor cost associated with feature, overides spec derived labor cost",
                    "type": "string"
                },
                "path": {
                    "description": "Path geometry for the Conduit",
                    "$ref": "https://geojson.org/schema/LineString.json"
                }
            },
            "allOf": [
                {
                    "$ref": "./Feature.schema.json"
                }
            ]
        }
    }
}
