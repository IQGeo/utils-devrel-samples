{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "Route.schema.json",
    "title": "Route",
    "definitions": {
        "Route": {
            "$id": "#Route",
            "description": "Parent schema for route objects.",
            "type": "object",
            "properties": {
                "inStructure": {
                    "description": "Start structure, if any (URN)",
                    "type": "string"
                },
                "outStructure": {
                    "description": "End structure, if any (URN)",
                    "type": "string"
                },
                "length": {
                    "description": "Length of the route (metres",
                    "type": "number"
                },
                "laborCosts": {
                    "description": "Labor cost associated with feature, overides spec derived labor cost",
                    "type": "string"
                },
                "path": {
                    "description": "Path geometry for the Route",
                    "$ref": "https://geojson.org/schema/LineString.json"
                }
            },
            "allOf": [
                {
                    "$ref": "./Feature.schema.json"
                }
            ]
        }
    }
}
