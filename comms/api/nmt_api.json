{
    "openapi": "3.0.0",
    "info": {
        "title": "IQGeo Network Manager Telecom API",
        "version": "1.0.0",
        "description": "APIs to support network provisioning and assurance. These include TMF style APIs for feature query, insert and update, as well as a network trace API. Further detail is provided in product documentation. This file can be imported into Postman, viewed using Swagger UI or a VSCode OpenAPI extension."
    },
    "servers": [
        {
            "url": "http://localhost:82/modules/comms/api/v1",
            "description": "Local development server"
        }
    ],
    "tags": [
        {
            "name": "General",
            "description": "General APIs for querying and maintaining network data. These are modelled on the TMF resource inventory APIs and include additional parameters for accessing data in designs and authorisation against an application. On the server, a set of API triggers can be written to do additional processing for API calls."
        },
        {
            "name": "Network Assurance",
            "description": "APIs to support network assurance."
        }
    ],
    "paths": {
        "/resourceInventoryManagement/resource/{featureType}/{id}": {
            "get": {
                "summary": "Get feature by id",
                "description": "Return feature with given id. Fields returned can be limited using the 'fields' parameter. Data from a specific design can be obtained using the 'delta' parameter. The returned feature data will be formatted as per the schema for the feature type.",
                "tags": ["General"],
                "parameters": [
                    {
                        "name": "featureType",
                        "in": "path",
                        "description": "Type of feature.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "fiber_cable"
                    },
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Identifier of feature.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "1"
                    },
                    {
                        "name": "application",
                        "in": "query",
                        "description": "Application context for request.",
                        "example": "mywcom",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "delta",
                        "in": "query",
                        "required": false,
                        "description": "Database delta for request",
                        "schema": {
                            "type": "string"
                        },
                        "example": "design/CC4970"
                    },
                    {
                        "name": "fields",
                        "in": "query",
                        "required": false,
                        "description": "Comma separated list of fields names. Only these fields will be included in the results",
                        "schema": {
                            "type": "string"
                        },
                        "example": "name,specification"
                    },
                    {
                        "name": "includeLobs",
                        "in": "query",
                        "required": false,
                        "description": "Controls whether the response includes the contents of 'large object' fields such as image and file fields",
                        "schema": {
                            "type": "boolean",
                            "default": false
                        },
                        "example": true
                    },
                    {
                        "name": "includeCalculatedReferenceSets",
                        "in": "query",
                        "required": false,
                        "description": "Controls whether the response includes calculated reference sets, eg circuits attached to an address",
                        "schema": {
                            "type": "boolean",
                            "default": false
                        },
                        "example": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Resource"
                                }
                            }
