        "/networkTrace": {
            "get": {
                "summary": "Perform network trace.",
                "description": "Perform network trace from a feature up to the end of the connected path or specified distance. The latter can be used for finding geographic location from OTDR trace data.",
                "tags": ["Network Assurance"],
                "parameters": [
                    {
                        "name": "network",
                        "in": "query",
                        "description": "Name of configured network to trace.",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "mywcom_fiber"
                        }
                    },
                    {
                        "name": "from",
                        "in": "query",
                        "required": true,
                        "description": "Start node of trace. Can be URN specifying range of ports on equipment, range of strands on a cable segment.",
                        "schema": {
                            "type": "string"
                        },
                        "examples": {
                            "equipment_port": {
                                "summary": "Equipment port",
                                "value": "fiber_patch_panel/1?pins=out:1"
                            },
                            "cable_strand": {
                                "summary": "Cable strand",
                                "value": "mywcom_fiber_segment/1?pins=out:1"
                            },
                            "circuit": {
                                "summary": "Circuit",
                                "value": "ftth_circuit/1?pins=out:1"
                            }
                        }
                    },
                    {
                        "name": "direction",
                        "in": "query",
                        "description": "Direction of trace.",
                        "schema": {
                            "type": "string",
                            "default": "downstream",
                            "enum": ["upstream", "downstream", "both"]
                        },
                        "example": "downstream"
                    },
                    {
                        "name": "maxDistance",
                        "in": "query",
                        "description": "Maximum distance to trace in metres. Trace will stop at this distance or end of connected path whichever is first.",
                        "schema": {
                            "type": "integer"
                        },
                        "example": "1000"
                    },
                    {
                        "name": "maxNodes",
                        "in": "query",
                        "description": "Maximum number of nodes to visit. If this number is exceeded then an error is returned.",
                        "schema": {
                            "type": "integer"
                        },
                        "example": 500
                    },
                    {
                        "name": "application",
                        "in": "query",
                        "description": "Application context for request.",
                        "example": "mywcom",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "delta",
                        "in": "query",
                        "required": false,
                        "description": "Database delta for request",
                        "schema": {
                            "type": "string"
                        },
                        "example": "design/CC4970"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfull trace. Returns network trace tree.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/networkTrace"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request. Invalid parameters provided. For example, invalid URN.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized. Invalid authentication token provided or role."
                    },
                    "500": {
                        "description": "Internal server error. Report to system administrator."
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Error": {
                "description": "Additional information for errors",
                "type": "object",
                "properties": {
                    "code": {
                        "description": "Application relevant detail, defined in the API or a common list",
                        "type": "integer"
                    },
                    "reason": {
                        "description": "Explanation of the reason for the error which can be shown to a client user",
                        "type": "string"
                    },
                    "message": {
                        "description": "More details and corrective actions related to the error which can be shown to a client user",
                        "type": "string"
                    }
                }
            },
            "qurn": {
                "description": "Qualified URN. Format is \\<datasource\\>\\/\\<featureType\\>\\/\\<id\\>?\\<qualifiers\\>. Datasource and qualifiers are optional.",
                "type": "string"
            },
            "networkTrace": {
                "description": "Trace tree.",
                "type": "object",
                "properties": {
                    "ends": {
                        "description": "Index of nodes that form the end of the trace.",
                        "type": "array",
                        "items": {
                            "type": "integer"
                        }
                    },
                    "nodes": {
                        "description": "List of nodes in trace. These can form a tree.",
                        "type": "array",
                        "items": {
                            "type": "object",
                            "description": "A node in the trace tree. These map to linear features or point features. For example, fiber cables, connections or ports on equipment",
                            "properties": {
                                "parent": {
                                    "description": "Parent node of this node. Index into nodes list. 0 indicates root node.",
                                    "type": "integer"
                                },
                                "resource": {
                                    "description": "Resource (feature) associated with this node (URN)",
                                    "type": "string"
                                },
                                "direction": {
                                    "description": "Direction of trace",
                                    "type": "string",
                                    "enum": ["upstream", "downstream", "both"]
                                },
                                "distance": {
                                    "description": "Total distance along the trace at this node (m). For linear features this is the distance before it moves to next node.",
                                    "type": "number"
                                },
                                "length": {
                                    "description": "Distance between start and stop coordinates (m)",
                                    "type": "string"
                                },
                                "fibers": {
                                    "description": "Fiber strands the trace passes through. Either a single number or a range 'low:high'",
                                    "type": "string"
                                },
                                "ports": {
                                    "description": "Ports the trace passes through. Format is: 'side:range' where side is 'in' or 'out' and range is a single number or 'low:high'.",
                                    "type": "string"
                                },
                                "startCoordinate": {
                                    "description": "Start coordinate of node",
                                    "type": "array",
                                    "items": {
                                        "type": "number"
                                    }
                                },
                                "stopCoordinate": {
                                    "description": "Stop coordinate of node (which might be part way along a linear feature).",
                                    "type": "array",
                                    "items": {
                                        "type": "number"
                                    }
                                },
                                "individualLoss": {
                                    "description": "Individual loss for the port or strand (dB).",
                                    "type": "number"
                                },
                                "cumulativeLoss": {
                                    "description": "Cumulative loss for trace up to this node (dB).",
                                    "type": "number"
                                },
                                "lineOfCount": {
                                    "description": "Line of count assignment for the port or strand",
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "resources": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Resource"
                        }
                    }
                }
            },
            "Resource": {
                "description": "Resource inventory schema. See schema in api/schema directory.",
                "type": "object"
            }
        }
    }
}
