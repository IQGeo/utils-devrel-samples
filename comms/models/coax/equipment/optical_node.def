{
    "datasource": "myworld",
    "name": "optical_node",
    "external_name": "{:coax_optical_node_field_name}",
    "title": "[name]",
    "short_description": null,
    "track_changes": true,
    "versioned": true,
    "editable": {
        "insert_from_gui": false,
        "update_from_gui": true,
        "delete_from_gui": true
    },
    "fields": [
        {
            "name": "id",
            "external_name": "{:id_field_name}",
            "type": "integer",
            "key": true,
            "generator": "sequence"
        },
        {
            "name": "name",
            "external_name": "{:name_field_name}",
            "type": "string(64)"
        },
        {
            "name": "root_housing",
            "external_name": "{:housing_structure_field_name}",
            "type": "reference",
            "indexed": true,
            "read_only": true
        },
        {
            "name": "housing",
            "external_name": "{:housing_field_name}",
            "type": "reference",
            "indexed": true,
            "read_only": true
        },
        {
            "name": "labor_costs",
            "external_name": "{:feature_labor_costs_name}",
            "type": "string()"
        },
        {
            "name": "n_fiber_in_ports",
            "external_name": "{:n_in_ports_field_name}",
            "type": "integer"
        },
        {
            "name": "equipment",
            "external_name": "{:wall_box_feature_equipment_name}",
            "type": "reference_set",
            "value": "select()"
        },
        {
            "name": "coax_splices",
            "external_name": "{:cabinet_feature_fiber_splices_name}",
            "type": "reference_set",
            "value": "select()"
        },
        {
            "name": "n_coax_out_ports",
            "external_name": "{:coax_number_of_coaxial_outputs_field_name}",
            "type": "integer"
        },
        {
            "name": "frequency",
            "external_name": "{:coax_design_frequency_field_name}",
            "type": "double"
        },
        {
            "name": "output_frequency_1",
            "external_name": "{:coax_output_frequency_1_field_name}",
            "type": "double"
        },
        {
            "name": "output_frequency_2",
            "external_name": "{:coax_output_frequency_2_field_name}",
            "type": "double"
        },
        {
            "name": "output_frequency_3",
            "external_name": "{:coax_output_frequency_3_field_name}",
            "type": "double"
        },
        {
            "name": "output_frequency_4",
            "external_name": "{:coax_output_frequency_4_field_name}",
            "type": "double"
        },
        {
            "name": "related_power_supply",
            "external_name": "{:coax_related_power_supply_field_name}",
            "type": "reference"
        },
        {
            "name": "voltage",
            "external_name": "{:coax_voltage_field_name}",
            "type": "double"
        },
        {
            "name": "current_draw",
            "external_name": "{:coax_current_draw_field_name}",
            "type": "double"
        },
        {
            "name": "status",
            "external_name": "{:coax_construction_status_field_name}",
            "type": "string(64)"
        },
        {
            "name": "install_technician",
            "external_name": "{:coax_install_technician_field_name}",
            "type": "string(64)"
        },
        {
            "name": "install_date",
            "external_name": "{:coax_install_date_field_name}",
            "type": "date"
        },
        {
            "name": "type",
            "external_name": "{:fiber_cable_spec_type_name}",
            "type": "string(64)"
        },
        {
            "name": "distance_from_olt",
            "external_name": "{:coax_distance_from_olt_field_name}",
            "type": "double"
        },
        {
            "name": "specification",
            "external_name": "{:wall_box_feature_specification_name}",
            "type": "foreign_key(optical_node_spec)"
        },
        {
            "name": "fiber_connections",
            "type": "reference_set",
            "value": "select(mywcom_fiber_connection.in_object,mywcom_fiber_connection.out_object)",
            "read_only": true
        },
        {
            "name": "coax_connections",
            "type": "reference_set",
            "value": "select(mywcom_coax_connection.in_object,mywcom_coax_connection.out_object)",
            "read_only": true
        },
        {
            "name": "circuits",
            "external_name": "{:circuits_field_name}",
            "type": "reference_set",
            "read_only": true
        },
        {
            "name": "location",
            "external_name": "{:location_field_name}",
            "type": "point",
            "mandatory": "true"
        },
        {
            "name": "offset_geom",
            "external_name": "{:offset_field_name}",
            "type": "point"
        },
        {
            "name": "myw_orientation_offset_geom",
            "type": "double"
        },
        {
            "name": "directed",
            "external_name": "{:equipment_feature_directed_name}",
            "type": "boolean",
            "mandatory": true,
            "default": true
        }
    ]
}
