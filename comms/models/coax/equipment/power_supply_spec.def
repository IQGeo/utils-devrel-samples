            "type": "double"
        },
        {
            "name": "type",
            "external_name": "{:fiber_cable_spec_type_name}",
            "type": "string(64)"
        },
        {
            "name": "max_current_rating",
            "external_name": "{:copper_max_current_field_name}",
            "type": "double"
        },
        {
            "name": "output_voltage",
            "external_name": "{:copper_output_voltage_field_name}",
            "type": "double"
