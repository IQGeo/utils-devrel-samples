            "external_name": "{:coax_related_optical_node_field_name}",
            "type": "reference"
        },
        {
            "name": "specification",
            "external_name": "{:wall_box_feature_specification_name}",
            "type": "foreign_key(coax_amplifier_spec)"
        },
        {
            "name": "location",
            "external_name": "{:location_field_name}",
            "type": "point",
            "mandatory": "true"
        },
        {
            "name": "offset_geom",
            "external_name": "{:offset_field_name}",
            "type": "point"
        },
        {
            "name": "myw_orientation_offset_geom",
            "type": "double"
        },
        {
            "name": "directed",
            "external_name": "{:equipment_feature_directed_name}",
