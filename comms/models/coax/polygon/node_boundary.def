{
    "datasource": "myworld",
    "name": "node_boundary",
    "external_name": "{:coax_node_boundary_field_name}",
    "title": "[name]",
    "short_description": null,
    "track_changes": true,
    "versioned": true,
    "editable": {
        "insert_from_gui": true,
        "update_from_gui": true,
        "delete_from_gui": true
    },
    "fields": [
        {
            "name": "id",
            "external_name": "{:id_field_name}",
