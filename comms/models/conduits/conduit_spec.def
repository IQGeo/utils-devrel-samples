{
    "datasource": "myworld",
    "name": "conduit_spec",
    "external_name": "{:conduit_spec_external_name}",
    "title": "[name]",
    "short_description": "",
    "track_changes": true,
    "versioned": false,
    "editable": {
        "insert_from_gui": false,
        "delete_from_gui": false,
        "update_from_gui": false
    },
    "fields": [
        {
            "name": "name",
            "external_name": "{:name_field_name}",
            "type": "string(64)",
            "key": true
        },
        {
            "name": "model",
            "external_name": "{:spec_model_field_name}",
            "type": "string(64)"
        },
        {
            "name": "description",
            "external_name": "{:spec_description_field_name}",
            "type": "string()"
        },
        {
            "name": "manufacturer",
            "external_name": "{:spec_manufacturer_field_name}",
            "type": "string()"
        },
        {
            "name": "diameter",
            "external_name": "{:conduit_spec_diameter_name}",
            "type": "double",
            "unit": "mm",
            "unit_scale": "length"
        },
        {
            "name": "item_length",
            "external_name": "{:conduit_cable_spec_item_length_name}",
            "type": "double"
        },
        {
            "name": "item_length_unit",
            "external_name": "{:conduit_cable_spec_item_length_unit_name}",
            "type": "string(3)"
        },
        {
            "name": "item_cost",
            "external_name": "{:conduit_cable_spec_cost_name}",
            "type": "double"
        },
        {
            "name": "cost_currency",
            "external_name": "{:spec_currency_field_name}",
            "type": "string(3)"
        },
        {
            "name": "labor_costs",
            "external_name": "{:feature_labor_costs_name}",
            "type": "string()"
        },
        {
            "name": "retired",
            "external_name": "{:spec_retired_field_name}",
            "type": "boolean",
            "mandatory": true,
            "default": false
        }
    ],
    "queries": []
}
