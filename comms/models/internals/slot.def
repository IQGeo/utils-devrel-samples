{
    "datasource": "myworld",
    "name": "slot",
    "external_name": "{:slot_feature_external_name}",
    "title": "{display_name}: [name]",
    "track_changes": true,
    "versioned": true,
    "editable": {
        "update_from_gui": true,
        "delete_from_gui": true
    },
    "fields": [
        {
            "name": "id",
            "external_name": "{:id_field_name}",
            "type": "integer",
            "key": true,
            "generator": "sequence"
        },
        {
            "name": "name",
            "external_name": "{:name_field_name}",
            "type": "string(64)"
        },
        {
            "name": "root_housing",
            "external_name": "{:housing_structure_field_name}",
            "type": "reference",
            "indexed": true,
            "read_only": true
        },
        {
            "name": "housing",
            "external_name": "{:housing_field_name}",
            "type": "reference",
            "indexed": true,
            "read_only": true
        },
        {
            "name": "equipment",
            "external_name": "{:slot_feature_equipment_name}",
            "type": "reference_set",
            "value": "select()",
            "read_only": true
        },
        {
            "name": "labor_costs",
            "external_name": "{:feature_labor_costs_name}",
            "type": "string()"
        },
        {
            "name": "location",
            "external_name": "{:location_field_name}",
            "type": "point"
        },
        {
            "name": "circuits",
            "external_name": "{:circuits_field_name}",
            "type": "reference_set",
            "read_only": true
        }
    ],
    "groups": [],
    "searches": [
        {
            "value": "[name]",
            "description": "{title}"
        }
    ],
    "filters": []
}
